# Copy this file to .env.local for local development or add these keys to Vercel.
#
# Persistent cache.
# Local zero-cost option:
DATABASE_URL="pglite://.data/music-link-swapper"
#
# Production free-tier option: create a Neon Postgres database and use its
# pooled connection string. Keep sslmode=require.
# DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/DB?sslmode=require"

# Spotify Web Player matching is enabled by default. Set to false as a kill switch.
SPOTIFY_WEB_MATCHING_ENABLED="true"

# YouTube Data API matching is enabled when YOUTUBE_API_KEY exists. Set to false as a kill switch.
YOUTUBE_MATCHING_ENABLED="true"

# TIDAL matching/search is enabled when client credentials exist. Set to false as a kill switch.
TIDAL_MATCHING_ENABLED="true"
TIDAL_CLIENT_ID=""
TIDAL_CLIENT_SECRET=""
TIDAL_COUNTRY_CODE="BR"

# stats-lc bridge can enrich Spotify <-> Apple Music from stats.fm catalog IDs.
STATSLC_BRIDGE_ENABLED="true"
STATSLC_BRIDGE_URL="https://statslc.leosaquetto.com/api/catalog-link-bridge"
STATSLC_BRIDGE_TOKEN=""

# Optional shared secret for trusted manual corrections. Generate with:
# node -e "console.log(crypto.randomUUID())"
MANUAL_LINK_TOKEN=""

# Optional. When absent, YouTube/YouTube Music are shown only when a trusted provider
# or manual correction returns a direct video URL.
YOUTUBE_API_KEY=""
